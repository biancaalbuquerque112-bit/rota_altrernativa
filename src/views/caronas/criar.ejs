<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
        <div class="auth-container">

    <a href="/" class="btn-back">
        ← Início
    </a>

</div>
<title>Nova Carona - Rota Alternativa</title>

<link rel="stylesheet" href="/style.css">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

</head>

<body class="auth-page">

<div class="auth-card">

    <h1>Nova Carona</h1>

    <% if (erro) { %>
        <div class="error-message">
            <%= erro %>
        </div>
    <% } %>

    <form action="/caronas" method="POST">

     <label>Rota</label>

<div class="rota-group">

    <select name="rotaId" required>
        <% rotas.forEach(rota => { %>
            <option value="<%= rota.id %>">
                <%= rota.origem %> → <%= rota.destino %>
            </option>
        <% }) %>
    </select>

    <a href="/rotas/criar" class="btn-add-route">
        + Nova Rota
    </a>

</div>
        <label>Vagas</label>

        <input
            type="number"
            name="vagas"
            min="1"
            placeholder="Quantidade de vagas"
            required
        >

        <label>Horário</label>

        <input
            type="datetime-local"
            name="horario"
            required
        >

        <button
            type="submit"
            class="btn-primary"
        >
            Criar Carona
        </button>

    </form>

    <a href="/caronas" class="auth-link">
        ← Voltar para Caronas
    </a>

</div>

<div id="cursor"></div>
<div id="cursorRing"></div>

<script src="/script.js"></script>

</body>
</html>