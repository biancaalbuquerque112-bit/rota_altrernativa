<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <div class="auth-container">

    <a href="/" class="btn-back">
        ← Início
    </a>

</div>

    <title>Minhas Caronas - Rota Alternativa</title>

    <link rel="stylesheet" href="/style.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>

<div id="cursor"></div>
<div id="cursorRing"></div>

<script src="/script.js"></script>


<body>

<%- include('../partials/navbar') %>

<div class="dashboard">

    <div class="dashboard-header">

        <div>
            <span class="section-label">
                PAINEL
            </span>

            <h1>Minhas Caronas</h1>

            <p>
                Bem-vinda, <%= usuario.nome %>
            </p>
        </div>

        <div class="dashboard-actions">

            <a href="/caronas/criar" class="btn-primary">
                Nova Carona
            </a>

            <a href="/logout" class="btn-secondary">
                Sair
            </a>

        </div>

    </div>

    <% if (caronas.length === 0) { %>

        <div class="empty-card">

            <h3>Nenhuma carona cadastrada</h3>

            <p>
                Crie sua primeira carona para começar.
            </p>

        </div>

    <% } else { %>

    <div class="table-card">

        <table class="dashboard-table">

            <thead>

                <tr>
                    <th>Motorista</th>
                    <th>Origem</th>
                    <th>Destino</th>
                    <th>Horário</th>
                    <th>Vagas</th>
                    <th>Status</th>
                    <th>Reservar</th>

                </tr>

            </thead>

            <tbody>

                <% caronas.forEach(carona => { %>

                <tr>

                    <td>
                        <%= carona.motorista?.nome || "-" %>
                    </td>

                    <td>
                        <%= carona.Rotum?.origem || carona.Rota?.origem || "-" %>
                    </td>

                    <td>
                        <%= carona.Rotum?.destino || carona.Rota?.destino || "-" %>
                    </td>

                    <td>
                        <%= new Date(carona.horario).toLocaleString('pt-BR') %>
                    </td>

                    <td>
                        <%= carona.vagas %>
                    </td>

                    <td>
                        <span class="status-badge">
                            <%= carona.status %>
                        </span>
                    </td>
                    <td>
                        <% if(carona.motorista?.telefone) { %>

                            <a
                                href="https://wa.me/55<%= carona.motorista.telefone.replace(/\D/g,'') %>?text=Olá! Tenho interesse na carona de <%= carona.Rota?.origem %> para <%= carona.Rota?.destino %>."
                                target="_blank"
                                class="btn-primary"
                            >
                                Reservar
                            </a>

                        <% } else { %>

                            <span>Sem contato</span>

                        <% } %>
                    </td>

                </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

    <% } %>

</div>
<div class="table-card">

    <h2>Rotas Disponíveis</h2>

    <div class="cards-grid">

        <% rotas.forEach(rota => { %>

            <div class="rota-card">

                <h3>
                    <%= rota.origem %> → <%= rota.destino %>
                </h3>

                <p>
                    Distância:
                    <%= rota.distancia || "Não informada" %> km
                </p>

            </div>

        <% }) %>

    </div>

</div>

</body>
</html>