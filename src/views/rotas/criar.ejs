<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Nova Rota - Rota Alternativa</title>

<link rel="stylesheet" href="/style.css">

</head>

<body class="auth-page">

<a href="/" class="btn-back-home">
    ← Início
</a>

<div class="auth-card">

    <h1>Cadastrar Rota</h1>

    <% if (erro) { %>
        <p class="error-message"><%= erro %></p>
    <% } %>

    <form action="/rotas" method="POST">

        <label>Origem</label>

        <input
            type="text"
            name="origem"
            placeholder="Ex: Serraria"
            required>

        <label>Destino</label>

        <input
            type="text"
            name="destino"
            placeholder="Ex: Pajuçara"
            required>

        <label>Distância</label>

        <input
            type="number"
            step="0.1"
            name="distancia"
            placeholder="Ex: 12.5 km">

        <button
            type="submit"
            class="btn-primary">
            Salvar Rota
        </button>

    </form>

    <a href="/rotas" class="auth-link">
        ← Voltar para Rotas
    </a>

</div>

<div id="cursor" class="cursor"></div>
<div id="cursorRing" class="cursor-ring"></div>

<script src="/script.js"></script>

</body>
</html>