<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Editar Rota</title>
</head>
<body>

<h1>Editar Rota</h1>

<% if (erro) { %>
<p style="color:red"><%= erro %></p>
<% } %>

<form action="/rotas/<%= rota.id %>/editar" method="POST">

    <input
        type="text"
        name="origem"
        value="<%= rota.origem %>"
        required>

    <br><br>

    <input
        type="text"
        name="destino"
        value="<%= rota.destino %>"
        required>

    <br><br>

    <input
        type="number"
        step="0.1"
        name="distancia"
        value="<%= rota.distancia %>">

    <br><br>

    <button type="submit">
        Atualizar
    </button>

</form>

<br>

<a href="/rotas">
    Voltar
</a>

</body>
</html>