<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Minhas Rotas - Rota Alternativa</title>

    <link rel="stylesheet" href="/style.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>

<body>

<div id="cursor"></div>
<div id="cursorRing"></div>

<%- include('../partials/navbar') %>

<div class="auth-container">

    <a href="/" class="btn-back">
        ← Início
    </a>

</div>

<div class="dashboard">

    <div class="dashboard-header">

    <div>
        <span class="section-label">PAINEL</span>
        <h1>Minhas Rotas</h1>
        <p>Gerencie suas rotas cadastradas</p>
    </div>

    <div class="dashboard-actions">

        <a href="/caronas" class="btn-secondary">
            ← Voltar ao Painel
        </a>

        <a href="/rotas/criar" class="btn-primary">
            Nova Rota
        </a>

    </div>

</div>

    <% if(rotas.length === 0) { %>

        <div class="empty-card">

            <h3>Nenhuma rota cadastrada</h3>

            <p>
                Clique em "Nova Rota" para criar sua primeira rota.
            </p>

        </div>

    <% } else { %>

        <div class="cards-grid">

            <% rotas.forEach(rota => { %>

                <div class="rota-card">

                    <div class="rota-header">

                        <h3>
                            <%= rota.origem %> → <%= rota.destino %>
                        </h3>

                    </div>

                    <p class="rota-info">
                        📍 Distância:
                        <strong>
                            <%= rota.distancia || "Não informada" %> km
                        </strong>
                    </p>

                    <div class="rota-actions">

                        <a href="/rotas/<%= rota.id %>/editar" class="btn-primary">
                            Editar
                        </a>

                        <form action="/rotas/<%= rota.id %>/deletar" method="POST">

                            <button type="submit" class="btn-danger">
                                Excluir
                            </button>

                        </form>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<script src="/script.js"></script>

</body>
</html>